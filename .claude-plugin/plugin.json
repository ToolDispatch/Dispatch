{
  "name": "dispatch",
  "display_name": "Dispatch",
  "description": "You don't know what you don't know. Neither does Claude Code. Dispatch monitors your conversation, detects task shifts, and proactively surfaces the best plugins, skills, and MCPs — then intercepts when Claude reaches for a weaker tool.",
  "version": "1.0.0",
  "author": {
    "name": "Visionairy",
    "url": "https://visionairy.biz",
    "email": "russ@visionairy.com"
  },
  "license": "MIT",
  "repository": "https://github.com/VisionAIrySE/Dispatch",
  "homepage": "https://dispatch.visionairy.biz",
  "icon": "../Dispatch Icon.png",
  "keywords": [
    "hooks",
    "plugin-discovery",
    "mcp",
    "tool-recommendation",
    "productivity",
    "developer-tools",
    "task-detection"
  ],
  "install": {
    "type": "script",
    "command": "bash install.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/dispatch.sh",
        "timeout_ms": 10000
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/dispatch-preuse.sh",
        "timeout_ms": 10000
      }
    ]
  },
  "requirements": {
    "python": ">=3.8",
    "node": ">=18"
  },
  "screenshots": [],
  "categories": [
    "productivity",
    "developer-tools",
    "ai-tools"
  ]
}